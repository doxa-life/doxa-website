msgstr ""
"Ressources imprimables et numériques pour promouvoir la sensibilisation et "
"l'engagement"

#: page-adopt.php:83
msgid "Helpful tips for sustaining long-term commitment"
msgstr "Conseils utiles pour maintenir un engagement à long terme"

